local TeleportService = game:GetService("TeleportService")
local Players = game:GetService("Players")

-- wait until the game is fully loaded
if not game:IsLoaded() then
    game.Loaded:Wait()
end

local player = Players.LocalPlayer
local PlaceID = game.PlaceId

local scriptToExecute = [[
loadstring(game:HttpGet("https://raw.githubusercontent.com/cookiesaltemail2-bot/sabserverhopper/main/mainhopper.lua"))()
]]

-- queue script for next server
if queue_on_teleport then
    queue_on_teleport(scriptToExecute)
elseif syn and syn.queue_on_teleport then
    syn.queue_on_teleport(scriptToExecute)
end

-- small delay so everything initializes
task.wait(3)

while true do
    local success, err = pcall(function()
        TeleportService:Teleport(PlaceID, player)
    end)

    if success then
        break
    else
        warn("Teleport failed, retrying...")
        task.wait(1)
    end
end
